# ─────────────────────────────────────────────────────────────
# QA System — Environment variables
# Copy this file to `.env.local` and fill in the values.
# In Vercel, add the SAME variables under: Project → Settings → Environment Variables.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; everything else is server-only.
# ─────────────────────────────────────────────────────────────

# ── Branding / identity ──────────────────────────────────────
# Shown in the header, page titles, and outgoing emails.
NEXT_PUBLIC_COMPANY_NAME=Acme Support

# Restrict sign-in / self-registration to this email domain.
# Leave BLANK to allow ANY email domain to register.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=acme.com

# ── App URL ──────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: your deployed URL, e.g. https://qa.acme.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (from your own project) ─────────────────────────
# Supabase Dashboard → Project Settings → API
#   • Project URL                    → NEXT_PUBLIC_SUPABASE_URL
#   • Project API keys: anon         → NEXT_PUBLIC_SUPABASE_ANON_KEY    (public, browser-safe)
#   • Project API keys: service_role → SUPABASE_SERVICE_ROLE_KEY        (SECRET — server only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth cookie domain ───────────────────────────────────────
# Leave BLANK for a standalone deploy (cookie stays on this host).
# Set to ".acme.com" only if you host several apps on subdomains and want shared sign-in.
AUTH_COOKIE_DOMAIN=

# ── Email (coaching + evaluation notifications) ──────────────
# Gmail SMTP app password, or any SMTP provider. Email is optional —
# if unset, the app runs fine and simply skips sending mail.
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=noreply@acme.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_FROM=Acme QA <noreply@acme.com>
# CC these addresses on team-lead digest emails (comma-separated, optional)
EMAIL_CC_SUPPORT_LEADS=

# ── Ticketing deep-links ─────────────────────────────────────
# Base URL a ticket number is appended to, so "Ticket 12345" links to your tool.
# Examples:
#   Freshdesk: https://acme.freshdesk.com/a/tickets/
#   Zendesk:   https://acme.zendesk.com/agent/tickets/
# Leave BLANK to render ticket numbers as plain text (no link).
NEXT_PUBLIC_TICKET_URL_TEMPLATE=

# ── Timezone ─────────────────────────────────────────────────
# IANA timezone used for the daily digest send time AND the weekly
# (Sunday→Saturday) QA rotation boundaries. Defaults to UTC if blank.
# Examples: America/New_York, Europe/London, Asia/Dubai, Africa/Cairo
DIGEST_TZ=

# ── Slack notifications (OPTIONAL) ───────────────────────────
# Bot token with scopes chat:write + users:read.email. If unset, Slack DMs are skipped.
SLACK_BOT_TOKEN=

# ── Cron protection ──────────────────────────────────────────
# Random secret required (as a Bearer token) to call the /api/cron/* endpoints.
# Generate one: `openssl rand -hex 32`
CRON_SECRET=your-random-secret

# ── ETL (OPTIONAL — only if importing legacy data via supabase/etl) ──
# Direct Postgres connection. Supabase → Settings → Database → Connection string (URI).
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
# Absolute path to a source spreadsheet to import (ETL scripts only, not the app)
QA_XLSX_PATH=
